---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: 'About', href: '/about/' },
  { name: 'Projects', href: '/projects/' },
  { name: 'Research', href: '/research/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'Contact', href: '/contact/' },
];
---

<footer class="relative border-t border-border">
  <!-- Gradient divider at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-50"></div>

  <div class="container-custom py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      <!-- Name and Title -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm" style="background: var(--accent-gradient);">
            A
          </div>
          <div>
            <p class="text-sm font-semibold text-text-primary">Azka Al Azkiyai</p>
            <p class="text-xs text-text-subtle">AI Security Researcher</p>
          </div>
        </div>
        <p class="text-xs text-text-subtle max-w-[240px] leading-relaxed">
          Securing AI systems through adversarial robustness and cryptographic verification.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs uppercase tracking-wider text-text-subtle font-mono mb-3">Navigation</h4>
        <nav class="flex flex-wrap gap-x-4 gap-y-1.5" aria-label="Footer navigation">
          {quickLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-text-muted hover:text-accent transition-colors duration-200"
            >
              {link.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social Links -->
      <div>
        <h4 class="text-xs uppercase tracking-wider text-text-subtle font-mono mb-3">Connect</h4>
        <nav class="flex items-center gap-3" aria-label="Social links">
          <!-- GitHub -->
          <a
            href="https://github.com/alazkiyai09"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-icon p-2 rounded-lg text-text-subtle hover:text-accent hover:bg-accent/10 transition-all duration-300"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/azka-alazkiyai/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-icon p-2 rounded-lg text-text-subtle hover:text-accent hover:bg-accent/10 transition-all duration-300"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>

          <!-- Email -->
          <a
            href="mailto:azka.alazkiyai@outlook.com"
            aria-label="Email"
            class="social-icon p-2 rounded-lg text-text-subtle hover:text-accent hover:bg-accent/10 transition-all duration-300"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
              />
            </svg>
          </a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-text-subtle">
        &copy; {currentYear} Azka Al Azkiyai. All rights reserved.
      </p>
      <p class="text-xs text-text-faint flex items-center gap-1.5">
        Built with
        <svg class="w-3 h-3 text-accent" viewBox="0 0 128 128" fill="currentColor">
          <path d="M50.4 78.5a75.1 75.1 0 00-28.5 6.9c24.2-65.1 44.7-40.5 44.7-40.5L73 31.5a1.6 1.6 0 012.2-.6l9.4 5.4a1.6 1.6 0 01.6 2.2l-6.8 11.8S99.8 28 81.6 16.8c-18-11.2-37 14.4-37 14.4S32.4 39.4 16 82h8.2a75.1 75.1 0 0126.2-3.5z"/>
        </svg>
        Astro
      </p>
    </div>
  </div>
</footer>

<style>
  .social-icon:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
  }
</style>
