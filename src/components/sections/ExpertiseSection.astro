---
import SectionHeader from '../ui/SectionHeader.astro';
import ExpertiseCard from '../ui/ExpertiseCard.astro';
import FadeIn from '../ui/FadeIn.astro';

const expertiseAreas = [
  {
    title: 'Fraud AI Deployment Engineering',
    subtitle: 'Current Launch Stack',
    description: 'I build and ship end-to-end fraud AI systems with clear API/UI boundaries, production health checks, and reproducible deployment workflows.',
    achievement: '7 live Cloud Run services (3 APIs + 4 UIs) in asia-southeast1',
    tags: ['Cloud Run', 'FastAPI', 'Streamlit', 'Production ML']
  },
  {
    title: 'Applied AI Security Workflows',
    subtitle: 'Research + Production',
    description: 'My current portfolio combines RAG investigation, healthcare fraud scoring, multi-agent monitoring, and LLM fine-tuning into one synchronized launch pipeline.',
    achievement: '5 synchronized GitHub repos with 40/40 Phase 3 validation checks',
    tags: ['RAG', 'LangGraph', 'QLoRA', 'Fraud Detection']
  }
];
---

<section class="section-padding">
  <div class="container-custom">
    <FadeIn delay="1">
      <SectionHeader
        label="EXPERTISE"
        title="What I Do"
        description="Security-focused AI engineering, from modeling workflows to live deployment."
      />
    </FadeIn>

    <div class="grid md:grid-cols-2 gap-6 mt-12 max-w-4xl mx-auto">
      {expertiseAreas.map((area, index) => (
        <FadeIn delay={(index + 2).toString() as '2' | '3'}>
          <ExpertiseCard
            title={area.title}
            subtitle={area.subtitle}
            description={area.description}
            achievement={area.achievement}
            tags={area.tags}
          />
        </FadeIn>
      ))}
    </div>
  </div>
</section>
