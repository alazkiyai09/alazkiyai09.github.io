---
import SectionHeader from '../ui/SectionHeader.astro';
import ProjectCard from '../ui/ProjectCard.astro';
import FadeIn from '../ui/FadeIn.astro';
import Button from '../ui/Button.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const totalProjects = allProjects.length;

const projects = [
  {
    title: 'SignGuard: Cryptographic FL Defense',
    description: 'Novel defense combining ECDSA signatures with anomaly detection and reputation scoring to protect federated learning from poisoning attacks.',
    impact: '94.5% attack detection rate with minimal overhead on honest participants',
    tags: ['PyTorch', 'Flower', 'ECDSA', 'Reputation Systems'],
    href: 'https://github.com/alazkiyai09/signguard'
  },
  {
    title: 'FL Security Ecosystem',
    description: 'Three-repository ecosystem covering core FL algorithms, adversarial attack/defense benchmarking with API-driven security testing, and privacy-preserving ML with CKKS/BFV encryption, TEE simulation, and ZK proof verification.',
    impact: '30+ implementations · 165,000+ lines · 5 crypto primitives',
    tags: ['PyTorch', 'Flower', 'TenSEAL', 'ZK-SNARKs'],
    href: 'https://github.com/alazkiyai09/federated-learning-core'
  },
  {
    title: 'Enterprise AI Platform',
    description: 'Modular enterprise AI platform: multi-agent orchestration with 4 agent types, 5 guardrail scanners, and hybrid RAG retrieval across three independently deployable repositories.',
    impact: '3 modules · 5 guardrails · 4 RAG modes · Kubernetes-ready',
    tags: ['FastAPI', 'LangGraph', 'LlamaIndex', 'Kubernetes'],
    href: 'https://github.com/alazkiyai09/enterprise-agents'
  }
];
---

<section class="section-padding">
  <div class="container-custom">
    <FadeIn delay="1">
      <SectionHeader
        label="PROVEN RESULTS"
        title="Selected Projects"
        description="My most impactful work in AI security and fraud detection."
      />
    </FadeIn>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {projects.map((project, index) => (
        <FadeIn delay={((index % 3) + 2).toString() as '2' | '3' | '4'}>
          <ProjectCard
            title={project.title}
            description={project.description}
            impact={project.impact}
            tags={project.tags}
            href={project.href}
          />
        </FadeIn>
      ))}
    </div>

    <FadeIn delay="5">
      <div class="mt-12 text-center">
        <Button href="/projects" variant="secondary" size="lg">
          View All Projects ({totalProjects})
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>
    </FadeIn>
  </div>
</section>
