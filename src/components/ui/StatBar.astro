---
/**
 * StatBar component - Server-trusted stat display.
 * Values are rendered directly to avoid transient "0" states when JS is delayed.
 */

interface StatItem {
  value: number;
  suffix?: string;
  label: string;
}

interface Props {
  stats: StatItem[];
  class?: string;
}

const {
  stats,
  class: className = ''
} = Astro.props;
---

<div class:list={[className, "stat-bar grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-0"]}>
  {stats.map((stat, index) => (
    <div
      class:list={[
        "stat-item text-center group",
        "md:border-r md:border-border",
        index === stats.length - 1 && "md:border-r-0"
      ]}
    >
      <div
        class="stat-value font-mono font-bold text-2xl md:text-stat gradient-text-animated"
      >
        {stat.value}{stat.suffix || ''}
      </div>
      <div class="stat-label text-xs uppercase tracking-wider text-text-subtle mt-1 group-hover:text-text-muted transition-colors">
        {stat.label}
      </div>
    </div>
  ))}
</div>
