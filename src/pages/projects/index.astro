---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import InteractiveFilter from '../../components/ui/InteractiveFilter.jsx';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.title || '').localeCompare(b.data.title || ''));

// Define filter categories with display labels
const filterCategories = ['All', 'FL Security', 'Fraud Detection', 'Production AI', 'Cryptography', 'Adversarial Attacks', 'Privacy ML'];

// Map all projects into raw serializable data for React component
const mappedProjects = sortedProjects.map(p => ({
  slug: p.slug,
  title: p.data.title,
  summary: p.data.summary,
  category: p.data.category,
  status: p.data.status,
  tags: p.data.tags || [],
  technologies: p.data.technologies || [],
  repository: p.data.repository,
  demo: p.data.demo
}));

const title = 'Projects - Azka';
const description = '9 focused research projects showcasing AI security — SignGuard FL defense, malware analysis, fraud detection pipelines, and published cryptographic research.';
---

<BaseLayout title={title} description={description}>
  <div class="section-padding container-custom">
    <!-- Section Header -->
    <SectionHeader
      label="Portfolio"
      title="Research Projects"
      description="9 focused projects showcasing my security research — from Byzantine-robust federated learning to malware analysis and published cryptographic methods"
      centered={true}
      class="mb-12"
    />

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent">9</div>
        <div class="text-sm text-text-muted">Curated Projects</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent-light">2</div>
        <div class="text-sm text-text-muted">Flagship</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent-pale">165K+</div>
        <div class="text-sm text-text-muted">Lines of Code</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent">1</div>
        <div class="text-sm text-text-muted">Published Research</div>
      </div>
    </div>

    <!-- Interactive Filter & Grid -->
    <InteractiveFilter client:load categories={filterCategories} projects={mappedProjects} />
  </div>
</BaseLayout>


