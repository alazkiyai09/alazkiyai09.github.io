---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import InteractiveFilter from '../../components/ui/InteractiveFilter.jsx';
import publications from '../../data/publications.json';
import activityLog from '../../data/activity-log.json';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.title || '').localeCompare(b.data.title || ''));
const featuredProjects = sortedProjects.filter((project) =>
  ['signguard', 'fl-security-ecosystem', 'enterprise-ai-platform'].includes(project.slug)
);
const totalPortfolioLoc = activityLog.activities.reduce((sum, activity) => {
  if (activity.type !== 'portfolio_complete') return sum;
  return sum + Number(activity.metrics?.linesOfCode || 0);
}, 0);
const compactLoc = totalPortfolioLoc >= 1000 ? `${Math.round(totalPortfolioLoc / 1000)}K+` : String(totalPortfolioLoc);
const publishedResearchCount = publications.publications.length;

// Define filter categories with display labels
const filterCategories = ['All', 'FL Security', 'Fraud Detection', 'Production AI', 'Cryptography', 'Finance', 'Healthcare'];

// Map all projects into raw serializable data for React component
const mappedProjects = sortedProjects.map(p => ({
  slug: p.slug,
  title: p.data.title,
  summary: p.data.summary,
  category: p.data.category,
  status: p.data.status,
  tags: p.data.tags || [],
  technologies: p.data.technologies || [],
  repository: p.data.repository,
  demo: p.data.demo
}));

const title = 'Projects - Azka';
const description = `${sortedProjects.length} ecosystem-focused projects spanning federated learning security, enterprise AI systems, fraud detection engineering, and IDX trading intelligence.`;
---

<BaseLayout title={title} description={description}>
  <div class="section-padding container-custom">
    <!-- Section Header -->
    <SectionHeader
      label="Portfolio"
      title="Research Projects"
      description={`${sortedProjects.length} focused projects across modular AI ecosystems — federated security, enterprise AI, fraud ML, healthcare AI, and applied cryptographic research`}
      centered={true}
      class="mb-12"
    />

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent">{sortedProjects.length}</div>
        <div class="text-sm text-text-muted">Curated Projects</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent-light">{featuredProjects.length}</div>
        <div class="text-sm text-text-muted">Featured</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent-pale">{compactLoc}</div>
        <div class="text-sm text-text-muted">Lines of Code</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-stat text-accent">{publishedResearchCount}</div>
        <div class="text-sm text-text-muted">Published Research</div>
      </div>
    </div>

    <!-- Interactive Filter & Grid -->
    <InteractiveFilter client:load categories={filterCategories} projects={mappedProjects} />
  </div>
</BaseLayout>
