---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ActivityFeed from '../components/features/ActivityFeed.astro';
import activityLog from '../data/activity-log.json';

const title = 'Activity Feed - Azka';
const description = 'Track my portfolio progress with detailed activity logs, commits, experiments, and milestones.';
const latestActivity = activityLog.activities[0];
const latestActivityDate = latestActivity
  ? new Date(latestActivity.date).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric'
    })
  : null;
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-bg-primary section-padding">
    <div class="container-custom">
      <SectionHeader
        label="ACTIVITY"
        title="Activity Feed"
        description="Chronological tracking of research portfolio progress"
        centered={true}
        level={1}
      />
      {latestActivityDate && (
        <p class="text-center text-sm text-text-subtle mt-3 mb-8">
          Latest logged update: {latestActivityDate}
        </p>
      )}

      <ActivityFeed limit={50} showHeader={false} />

      <!-- Activity Types -->
      <section class="mt-16">
        <h2 class="text-xl font-bold text-text-primary mb-6">Activity Types</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="glass-card p-6">
            <h3 class="font-bold mb-3 flex items-center gap-2 text-text-primary">
              <span class="text-2xl">🚀</span> Projects
            </h3>
            <p class="text-sm text-text-muted">
              Project starts, completions, and milestones.
            </p>
          </div>

          <div class="glass-card p-6">
            <h3 class="font-bold mb-3 flex items-center gap-2 text-text-primary">
              <span class="text-2xl">📄</span> Learning
            </h3>
            <p class="text-sm text-text-muted">
              Papers read, experiments run, and skills learned.
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
