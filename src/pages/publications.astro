---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import PublicationsSection from '../components/sections/Publications.astro';
import publications from '../data/publications.json';

const title = 'Publications - Azka Al Azkiyai';
const description = 'Peer-reviewed publications (2020-2021) and ongoing applied research in federated learning security and AI systems.';
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-bg-primary section-padding">
    <div class="container-custom">
      <SectionHeader
        label="PUBLICATIONS"
        title="Research Publications"
        description="Peer-reviewed publications plus current open-source research tracks"
        centered={true}
        level={1}
      />

      <PublicationsSection publications={publications.publications} />

      <p class="max-w-3xl mx-auto mt-8 text-sm text-text-subtle">
        Peer-reviewed publications listed here are from 2020-2021. Current federated learning security work is tracked as open-source project documentation and working-paper material in the Projects and Blog sections.
      </p>
    </div>
  </div>
</BaseLayout>
